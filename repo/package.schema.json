{
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "number"
    },
    "name": {
      "type": "string"
    },
    "binary_name": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          },
          "type": {
            "enum": [
              "zip",
              "targz",
              "raw"
            ],
            "type": "string"
          },
          "executable": {
            "type": "boolean"
          },
          "url_provider": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ]
      }
    },
    "shortcut": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        }
      },
      "required": []
    },
    "post_install_message": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "files"
  ],
  "$schema": "http://json-schema.org/draft-07/schema#"
}
